PORT=1323
LOG_BUFFER_SIZE=200
CORS_ORIGINS=*
ENVIRONMENT=development
DB_PATH=./data/radix.db
TURSO_URL=http://localhost:8080
TURSO_AUTH_TOKEN=

# goose CLI only (manual migrations: goose create/status/up/down) — the app
# itself runs embedded migrations programmatically, doesn't read these.
GOOSE_DRIVER=turso
GOOSE_DBSTRING=http://localhost:8080
GOOSE_MIGRATION_DIR=./internal/database/migrations
